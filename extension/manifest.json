{
  "manifest_version": 3,
  "name": "JARVIS-C Phishing Detector",
  "version": "1.0",

  "permissions": [
    "tabs",
    "activeTab",
    "notifications",
    "scripting"
  ],

  "host_permissions": [
    "https://jarvis-c-phishing-detector.onrender.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}